{
  "name": "google-flights-scraper",
  "version": "0.1.0",
  "description": "A Node.js core library for building and scraping Google Flights search queries.",
  "license": "MIT",
  "sideEffects": false,
  "keywords": [
    "google-flights",
    "flights",
    "scraper",
    "travel",
    "node",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/0xForelsket/google-flights-scraper.git"
  },
  "homepage": "https://github.com/0xForelsket/google-flights-scraper#readme",
  "bugs": {
    "url": "https://github.com/0xForelsket/google-flights-scraper/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --sourcemap --clean",
    "test": "vitest run",
    "check": "npm run build && npm run test",
    "prepublishOnly": "npm run check",
    "pack:check": "npm pack --dry-run"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "undici": "^8.1.0",
    "zod": "^4.3.6"
  }
}
